# Copy this to .env.local and fill in your values.
# Run install.ps1 to generate EZAD_PASSWORD_HASH automatically.

EZAD_USERNAME=admin
EZAD_PASSWORD_HASH=                # bcrypt hash -- generated by install.ps1
EZAD_SECRET=replace-with-a-long-random-string
EZAD_AD_GROUP=Domain Admins        # AD group allowed to log in; leave blank to disable AD auth
PORT=3000
